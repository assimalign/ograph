{
	"compilerOptions": {
		"composite": true,
		"target": "ES6",
		"lib": ["ES6"],
		"module": "commonjs",
		"outDir": "out",
		"rootDir": "src",
		"strict": true,
		"moduleResolution": "node",
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": [
		"src"
	],
	"exclude": [
		"node_modules"
	]
}