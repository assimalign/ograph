{
  "name": "vscode-extension",
  "displayName": "VS Code Extension",
  "description": "A Visual Studio Code extension for advanced syntax analysis and error highlighting.",
  "version": "0.1.0",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.50.0"
  },
  "activationEvents": [
    "onLanguage:yourLanguage"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [{
      "id": "yourLanguage",
      "extensions": [".yourLang"],
      "aliases": ["Your Language"]
    }],
    "grammars": [{
      "language": "yourLanguage",
      "scopeName": "source.yourLanguage",
      "path": "./syntaxes/ograph.tmLanguage.json"
    }]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "postinstall": "node ./node_modules/vscode/bin/install"
  },
  "devDependencies": {
    "typescript": "^4.0.0",
    "vscode": "^1.1.36"
  }
}