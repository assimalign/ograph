<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<TargetFrameworks>$(TargetFrameworkForLibraries)</TargetFrameworks>
	</PropertyGroup>
	<ItemGroup>
	  <Compile Remove="Elements\Types\.dev\**" />
	  <Compile Remove="Internal\Elements\**" />
	  <Compile Remove="System\**" />
	  <EmbeddedResource Remove="Elements\Types\.dev\**" />
	  <EmbeddedResource Remove="Internal\Elements\**" />
	  <EmbeddedResource Remove="System\**" />
	  <None Remove="Elements\Types\.dev\**" />
	  <None Remove="Internal\Elements\**" />
	  <None Remove="System\**" />
	</ItemGroup>
	<ItemGroup>
	  <Compile Remove="Elements\Edge\GdmEdge.T1.T2.cs" />
	</ItemGroup>
	<ItemGroup>
		<Compile Update="Properties\Resources.Designer.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>Resources.resx</DependentUpon>
		</Compile>
	</ItemGroup>
	<ItemGroup>
		<EmbeddedResource Update="Properties\Resources.resx">
			<Generator>ResXFileCodeGenerator</Generator>
			<LastGenOutput>Resources.Designer.cs</LastGenOutput>
		</EmbeddedResource>
	</ItemGroup>
</Project>
