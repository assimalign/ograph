{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$ref": "#/definitions/ograph-response",
    "definitions": {
        "ograph-response": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "$schema": {
                    "type": "string"
                },
                "@ograph.node": {
                    "type": "string"
                },
                "@ograph.status": {
                    "type": "number"
                },
                "pageInfo": {
                    "properties": {
                        "totalCount": {
                            "type": "number"
                        },
                        "hasNext": {
                            "type": "boolean"
                        },
                        "hasPrevious": {
                            "type": "boolean"
                        }
                    },
                    "additionalProperties": false,
                    "required": [
                        "totalCount",
                        "hasNext",
                        "hasPrevious"
                    ]
                },
                "data": {
                    "oneOf": [
                        {
                            "type": "array",
                            "minItems": 1,
                            "items": {
                                "$ref": "#/definitions/ograph-node"
                            }
                        },
                        {
                            "$ref": "#/definitions/ograph-node"
                        }
                    ]
                },
                "errors": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "code": {
                            "type": "string"
                        },
                        "message": {
                            "type": "string"
                        },
                        "details": {
                            "type": "array"
                        }
                    },
                    "required": [
                        "code",
                        "message"
                    ]
                }
            },
            "additionalProperties": false,
            "required": [
                "@ograph.node"
            ]
        },
        "ograph-node": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "@ograph.edges": {
                    "minProperties": 1,
                    "patternProperties": {
                        "^[a-z]": {
                            "$ref": "#/definitions/ograph-response"
                        }
                    }
                }
            },
            "patternProperties": {
                "^[a-z]": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "array"
                        },
                        {
                            "type": "boolean"
                        },
                        {
                            "type": "object",
                            "minProperties": 1
                        },
                        {
                            "type": "integer"
                        }
                    ]
                }
            }
        }
    }
}