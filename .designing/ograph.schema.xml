<?xml version="1.1" encoding="UTF-8"?>
<!--<?xml-model href="ograph.schema.xsd"?> -->
<ograph>

    <!-- Use the collection of models to stich together a single cohesive 
         Things to Consider:
         - Method & Route Combination Conflicts
    -->
    <model domain="users">
        <node label="users">
            <type name="UserQueryable">
                <property name="pageInfo" type="UserPageInfo"/>
                <property name="data" type="UserCollection" />
            </type>
            <type name="UserPageInfo">
                <property name="totalCount" type="Long"/>
            </type>
            <type name="UserCollection">
                <collection type="User"/>
            </type>
            <type name="User" is-root="true">
                <property name="userId" type="Guid" is-nullable="false" is-key="true" />
                <property name="firstName" type="String" is-nullable="true">
                    <meta key="description" value="The first name of the user." />
                </property>
                <property name="lastName" type="String" is-nullable="true" />
                <property name="middleName" type="String" is-nullable="true" />
                <property name="fullName" type="String" is-nullable="true" is-filterable="false" />
                <property name="birthDate" type="DateTime" is-nullable="true" />
            </type>
            <type name="UserTagCollection">
                <collection name="UserTag" />
            </type>
            <type name="UserTag">
                <porperty name="key" type="String" is-nullable="false" />
                <porperty name="value" type="String" is-nullable="false" />
            </type>
            <edge name="addresses" source-node="user" target-node="addresses" is-filterable="true" is-pageable="true" />
            <edge name="profile"   source-node="user" target-node="profiles" />
        </node>
        <node label="addresses">
            <property name="addressId" type="Guid" is-nullable="false" is-key="true" />
            <property name="streetOne" type="String" is-nullable="true" />
            <property name="streetTwo" type="String" is-nullable="true" />
            <property name="streetThree" type="String" is-nullable="true" />
            <property name="city" type="String" is-nullable="true" is-filterable="false" />
            <property name="stateOrRegion" type="String" is-nullable="true" />
            <property name="addressType" type="AddressEnum" is-nullable="false" />

            <type name="AddressEnum">
                <value>Primary</value>
                <value>Mailing</value>
            </type>
        </node>
        <node label="profiles">

        </node>
        <operation name="GetUsers">


        </operation>
        <operation name="CreateUser" node="users">
            <method>POST</method>
            <route value="/users/{userId}">
                <segment ordinal="1">users</segment>
                <segment ordinal="2">{userId:int}</segment>
            </route>
            <query>

            </query>
            <headers>
                <header key="" value="" />
            </headers>
            <request>

            </request>
        </operation>
        <operation name="UpdateUserAddress" node="addresses">
            <method>PUT</method>
            <route value="/users/{userId}/addresses/{addressId}">
                <segment ordinal="1" is-literal="true">users</segment>
                <segment ordinal="2" is-parameter="true">{userId:Guid}</segment>
                <segment ordinal="3" is-literal="true">address</segment>
                <segment ordinal="4" is-parameter="true">{addressId:Guid}</segment>
            </route>
            <headers>
                <key></key>
            </headers>
            <query-parameters>
                <query key="query" value-type="" />
            </query-parameters>
            <request name="UserAddressUpdateType">

            </request>
            <response>

            </response>
        </operation>
    </model>
</ograph>