<?xml version="1.0" encoding="utf-8"?>
<gdmx Version="1.0" xmlns="https://erpcore.com" Label="ErpCore">
    <Graph Label="Core">
        <ComplexType Label="AuditEntry">
            <Property Label="userId" Type="Users.UserId" IsReadOnly="true" IsNullable="false" />
            <Property Label="timestamp" Type="DateTimeOffset" IsReadOnly="true" IsNullable="false" />
            <Function Label="user">
                <ReturnType Type="ERpCore.Users.User"/>
            </Function>
        </ComplexType>
    </Graph>
    <Graph Label="Users">
        <Vertex Label="Users" Type="User">
            <Operation Label="search" Kind="Query" IsBound="true">
                <ReturnType Type="UserCollection" />
            </Operation>
            <Operation Label="lookup" Kind="Query">
                <Parameter Label="userId" Type="UserId" />
                <ReturnType Type="UserCollection" />
            </Operation>
            <Operation Label="create" Kind="Command">
                <Parameter Label="user" Type="UserCreateOrUpdate" />
                <ReturnType Type="User" />
            </Operation>
            <Operation Label="update" Kind="Command">
                <Parameter Label="userId" Type="UserId" />
                <Parameter Label="user" Type="UserCreateOrUpdate" />
                <ReturnType Type="User" />
            </Operation>
            <Operation Label="delete" Kind="Command">
                <Parameter Label="userId" Type="UserId" />
                <ReturnType Type="User" />
            </Operation>
            <Event Label="onDelete">
                <Binding On="DeleteUser" />
            </Event>
        </Vertex>
        <EntityType Label="User">
            <Key Property="id" />
            <Property Label="id" Type="UserId" IsReadOnly="false" IsNullable="false" />
            <Property Label="info" Type="UserDetails" IsReadOnly="false" IsNullable="false" />
            <Property Label="createdBy" Type="AuditEntry" IsReadOnly="false" IsNullable="false" />
            <Property Label="updatedBy" Type="Core.AuditEntry" IsReadOnly="false" IsNullable="true" />
        </EntityType>
        <CollectionType Label="UserCollection">
            <Item Type="User" />
        </CollectionType>
        <ComplexType Label="UserCreateOrUpdate">
            <Property Label="firstName" Type="String" IsReadOnly="false" IsNullable="false" />
            <Property Label="lastName" Type="String" IsReadOnly="false" IsNullable="false" />
            <Property Label="middleName" Type="String" IsReadOnly="false" IsNullable="true" />
            <Property Label="birthdate" Type="DateTime" IsReadOnly="false" IsNullable="false" />
        </ComplexType>
        <ComplexType Label="UserInfo">
            <Property Label="firstName" Type="String" IsReadOnly="false" IsNullable="false">
                <Meta>
                    <Key Decorator="">Description</Key>
                    <Value>The users first name.</Value>
                </Meta>
            </Property>
            <Property Label="lastName" Type="String" IsReadOnly="false" IsNullable="false" />
            <Property Label="middleName" Type="String" IsReadOnly="false" IsNullable="true" />
            <Property Label="birthdate" Type="DateTime" IsReadOnly="false" IsNullable="false" />
            <Property Label="fullName" Type="String" IsReadOnly="false" IsNullable="false"/>
            <Function Label="fullName" IsBound="true">
                <ReturnType Type="String" />
            </Function>
        </ComplexType>
        <ScalarType Label="UserId">
            <Format
                Pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" />
        </ScalarType>
    </Graph>
    <Graph Label="Employees">
        <Vertex Label="employees" Type="Employee">
            <Query Label="GetEmployees">
                <ReturnType Type="EmployeeList" />
            </Query>
            <Query Label="GetEmployeeById">
                <Parameter Label="employeeId" Type="EmployeeId" />
                <ReturnType Type="Employee" />
            </Query>
            <Command Label="CreateEmployee">
                <ReturnType Type="Employee" />
            </Command>
            <Command Label="UpdateEmployee">
                <Parameter Label="employeeId" Type="EmployeeId" />
                <Parameter Label="employee" Type="Employee" />
                <ReturnType Type="Employee" />
            </Command>
            <Command Label="DeleteEmployee">
                <Parameter Label="employeeId" Type="EmployeeId" />
                <ReturnType Type="Employee" />
            </Command>
            <Command Label="PatchEmployee">
                <Parameter Label="employeeId" Type="EmployeeId" />
                <ReturnType Type="Employee" />
            </Command>
            <Event Label="EmployeeCreated">
                <After Binding="CreateEmployee" />
            </Event>
            <Event Label="EmployeeUpdating">
                <On Binding="UpdateEmployee" />
            </Event>
            <Event Label="BeginEmployeeDelete">
                <Before Binding="DeleteEmployee" />
            </Event>
        </Vertex>
        <Vertex Label="employeeAddresses" Type="EmployeeAddress">
            <Query Label="GetEmployeeAddresses">
                <ReturnType Type="EmployeeAddressList" />
            </Query>
        </Vertex>
        <Vertex Label="employeeAddressTypes" Type="EmployeeAddressType">
            <Binding Kind="Command" Label="CreateEmployeeAddressType">
                <Action Kind="Create" />
            </Binding>
        </Vertex>
        <Vertex Label="employeeJobs" Type="EmployeeJob" />
        <Vertex Label="employeeTasks" Type="EmployeeTask" />
        <Vertex Label="employeeWorkItems" Type="EmployeeWorkItem" />
        <Vertex Label="employeeTaxInfo" Type="EmployeeTaxInfo" />
        <Edge Label="addresses" Source="employees" Target="employeeAddresses">
            <Operation Label="GetEmployeeAddresses">
                <Parameter Label="employeeId" Type="EmployeeId" />
                <ReturnType Type="EmployeeAddressList" />
            </Operation>
            <Operation Label="GetEmployeeAddressesById">
                <Parameter Label="employeeId" Type="EmployeeId" />
                <Parameter Label="addressId" Type="AddressId" />
                <ReturnType Type="EmployeeAddress" />
            </Operation>
        </Edge>
        <Edge Label="primaryAddress" Source="employees" Target="employeeAddresses">
            <Query Label="GetEmployeePrimaryAddresses">
                <Parameter Label="employeeId" Type="EmployeeId" />
                <ReturnType Type="EmployeeAddress" />
            </Query>
        </Edge>
        <Edge Label="types" Source="employeeAddresses" Target="employeeAddressTypes">
            <Query Label="GetEmployeeAddressTypes">
                <Parameter Label="employeeId" Type="EmployeeId" />
                <Parameter Label="addressId" Type="AddressId" />
                <ReturnType Type="EmployeeAddressType" />
            </Query>
        </Edge>
        <Edge Label="taxInfo" Source="employee" Target="taxInfo">

        </Edge>
        <Edge Label="jobs" Source="employees" Target="employeeJobs">

        </Edge>
        <Edge Label="tasks" Source="employeeJobs" Target="employeeTasks">

        </Edge>
        <Edge Label="tasks" Source="employees" Target="employeeTasks">

        </Edge>
        <Edge Label="workItems" Source="task" Target="workItem">

        </Edge>

        <ScalarType Label="EmployeeId">
            <Format Pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" />
        </ScalarType>
        <ScalarType Label="JobId">
            <Format
                Pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" />
        </ScalarType>
        <ScalarType Label="TaskId">
            <Format
                Pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" />
        </ScalarType>
        <ScalarType Label="WorkItemId">
            <Format
                Pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" />
        </ScalarType>
        <ScalarType Label="AddressId">
            <Format
                Pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" />
        </ScalarType>
        <EnumType Label="EmployeeKind">
            <Member Label="FullTime" Value="1" />
            <Member Label="PartTime" Value="2" />
            <Member Label="Contractor" Value="3" />
        </EnumType>
        <ComplexType Label="Address">
            <Property Label="streetOne" Type="String" IsReadOnly="false" IsNullable="false" />
            <Property Label="streetTwo" Type="String" IsReadOnly="false" IsNullable="false" />
            <Property Label="streetThree" Type="String" IsReadOnly="false" IsNullable="true" />
            <Property Label="streetFour" Type="String" IsReadOnly="false" IsNullable="true" />
            <Property Label="city" Type="String" IsReadOnly="false" IsNullable="false" />
            <Property Label="state" Type="String" IsReadOnly="false" IsNullable="false" />
            <Property Label="zipCode" Type="String" IsReadOnly="false" IsNullable="false" />
            <Property Label="fullAddress" Type="String" IsReadOnly="false" IsNullable="false" >

            </Property>
        </ComplexType>
        <ComplexType Label="EmployeeInfo">
            <Property Label="firstName" Type="String" IsReadOnly="false" IsNullable="false"
            />
            <Property Label="lastName" Type="String" IsReadOnly="false" IsNullable="false"
            />
            <Property Label="middleName" Type="String" IsReadOnly="false" IsNullable="true"
            />
            <Property Label="fullName" Type="String" IsReadOnly="true" IsNullable="true"
            >
                <Binding Kind="Resolver">
                    <ReturnType Type="String" />
                </Binding>
            </Property>
            <Property Label="Birthday" Type="Date" />
        </ComplexType>
        <ComplexType Label="AuditEntry">
            <Property Label="userId" Type="UserId" />
            <Property Label="timestamp" Type="DateTime" />
            <Property Label="user" Type="User" IsReadOnly="true">
                <Resolver Label="ResolveUserInfo" Kind="Property">
                    <Output Type="User" />
                </Resolver>
            </Property>
        </ComplexType>
        <ComplexType Label="EmployeeUpdateOrCreate">
            <Property Label="info" Type="EmployeeInfo" />
        </ComplexType>
        <EntityType Label="Employee">
            <Key Property="id" />
            <Property Label="id" Type="EmployeeId">
                <Meta>
                    <Key Decorator="@provider">Description</Key>
                    <Value>The employee identifier.</Value>
                </Meta>
            </Property>
            <Property Label="userId" Type="users.UserId" />
            <Property Label="info" Type="EmployeeInfo" />
        </EntityType>
        <EntityType Label="EmployeeAddress">
            <Key Property="id" />
            <Property Label="id" Type="AddressId" />
            <Property Label="employeeId" Type="EmployeeId" />
            <Property Label="address" Type="Address" />
        </EntityType>
        <EntityType Label="EmployeeJob">
            <Key Property="id" />
            <Property Label="id" Type="JobId" />
        </EntityType>
        <EntityType Label="EmployeeTask">
            <Key Property="id" />
            <Property Label="id" Type="TaskId" />
        </EntityType>
        <EntityType Label="EmployeeWorkItem">
            <Key Property="id" />
            <Property Label="id" Type="WorkItemId" />
        </EntityType>
        <CollectionType Label="EmployeeList">
            <Item Type="Employee" />
        </CollectionType>
        <CollectionType Label="EmployeeAddressList">
            <Item Type="EmployeeAddress" />
        </CollectionType>
        <CollectionType Label="EmployeeJobList">
            <Item Type="EmployeeJob" />
        </CollectionType>
        <CollectionType Label="EmployeeTaskList">
            <Item Type="EmployeeTask" />
        </CollectionType>
    </Graph>
    <Graph Label="Organization">
        <Vertex Label="OrganizationAddress">
        </Vertex>
    </Graph>
    <Graph Label="Inventory">
    </Graph>
    <Graph Label="Warehouses">
    </Graph>
    <Graph Label="Packaging">
    </Graph>
    <Graph Label="Shipping">
    </Graph>
</gdmx>