        </ScalarType>
        <ScalarType Label="WorkItemId">
            <Format Pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" />
        </ScalarType>
        <ScalarType Label="AddressId">
            <Format Pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" />
        </ScalarType>
        <EnumType Label="EmployeeKind">
            <Member Label="FullTime" Value="1" />
            <Member Label="PartTime" />
        </EnumType>
        <ComplexType Label="Address">
            <Property Label="streetOne" Type="String" />
            <Property Label="streetTwo" Type="String" />
            <Property Label="streetThree" Type="String" />
            <Property Label="streetFour" Type="String" />
            <Property Label="city" Type="String" />
            <Property Label="state" Type="String" />
            <Property Label="zipCode" Type="String" />
        </ComplexType>
        <ComplexType Label="EmployeeInfo">
            <Property Label="firstName" Type="String" IsReadOnly="false" IsNullable="true" IsComputed="false" />
            <Property Label="lastName" Type="String" IsReadOnly="false" IsNullable="true" IsComputed="false" />
            <Property Label="middleName" Type="String" IsReadOnly="false" IsNullable="true" IsComputed="false" />
            <Property Label="fullName" Type="String" IsReadOnly="true" IsNullable="true" IsComputed="true">
                <Binding Kind="Resolver">
                    <ReturnType Type="String"/>
                </Binding>
            </Property>
            <Property Label="Birthday" Type="Date" />
        </ComplexType>
        <ComplexType Label="AuditEntry">
            <Property Label="userId" Type="UserId" />
            <Property Label="timestamp" Type="DateTime" />
            <Property Label="user" Type="User" IsReadOnly="true">
                <Resolver Label="ResolveUserInfo" Kind="Property">
                    <Output Type="User" />
                </Resolver>
            </Property>
        </ComplexType>
        <ComplexType Label="EmployeeUpdateOrCreate">
            <Property Label="info" Type="EmployeeInfo" />
        </ComplexType>
        <EntityType Label="Employee">
            <Key Property="id" />
            <Property Label="id" Type="EmployeeId">
                <Meta>
                    <Key Decorator="@provider">Description</Key>
                    <Value>The employee identifier.</Value>
                </Meta>
            </Property>
            <Property Label="info" Type="EmployeeInfo" />
        </EntityType>
        <EntityType Label="EmployeeAddress">
            <Key Property="id" />
