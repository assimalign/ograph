    <Graph Label="users" Uri="https://endpoint.com/api/users/$graph">
        <!-- Use the collection of models to stich together a single cohesive 
        Things to Consider:
            - Method & Route Combination Conflicts

         There should be two types of models
         - Graph Relationship Model
         - Service Model: 

        Exmaple Routes: (User Domain)
        Users Node: Label - users 
            - GET       /api/users
            - GET       /api/users/{userId}
            - POST      /api/users
            - PUT       /api/users/{userId}
            - DELETE    /api/users/{userId}

        Users Profile Node: Label - profile [OneToOne]
            - GET       /api/users/profiles
            - GET       /api/users/{userId}/profile
            - POST      /api/users/{userId}/profile
            - PUT       /api/users/{userId}/profile
            - DELETE    /api/users/{userId}/profile

        Users Addresses: Label - addresses [OneToMany]
            - GET       /api/users/addresses
            - GET       /api/users/{userId}/addresses
            - GET       /api/users/{userId}/primaryAddress [Edge]
            - GET       /api/users/{userId}/addresses/{addressId}
            - POST      /api/users/{userId}/addresses
            - PUT       /api/users/{userId}/addresses/{addressId}
            - DELETE    /api/users/{userId}/addresses/{addressId}

        Users Address Types Node: Label - addresseTypes [OneToOne]
            - GET       /api/users/addressTypes
            - GET       /api/users/addresses/{addressId}/addressType
            - GET       /api/users/{userId}/addresses/{addressId}/addressType
            - POST      /api/users/addressTypes
            - PUT       /api/users/addressTypes/{addressTypeId}
            - DELETE    /api/users/addressTypes/{addressTypeId}
    -->
        <Vertex Label="users" Type="User">
            <!-- /api/users -->
            <Query Label="GetUsers" IsBound="true">
                <ReturnType Type="UserCollection" />
            </Query>
            <!-- /api/users/{userId} -->
            <Query Label="GetUserById">
                <ReturnType Type="User" />
                <Meta>
                    <Key>Description</Key>
                    <Value>Gets a user by the user's identifier</Value>
                </Meta>
                <Meta>
                    <Key Decorator="@security">Permissions</Key>
                    <Value>

                    </Value>
                </Meta>
            </Query>
            <!-- POST       /api/users/ -->
            <Command Label="CreateUser">
                <ReturnType Type="User"/>
            </Command>
            <!-- DELETE     /api/users/{userId} -->
            <Command Label="DeleteUser">
                <ReturnType Type="Null"/>
            </Command>
        </Vertex>
        <Vertex Label="address" Type="UserAddress">
            <!-- GET        /api/users/addresses or /api/userAddresses -->
            <Query Label="GetAllUserAddresses">
                <ReturnType Type="UserAddressCollection"/>
                <Meta>
                    <Key>Description</Key>
                    <Value>Gets all user addresses.</Value>
                </Meta>
                <Meta>
                    <Key Decorator="@security">Permissions</Key>
                    <Value>
                        <Permission Priority="1">System.Admin</Permission>
                        <Permission Priority="2">Users.Admin</Permission>
                    </Value>
                </Meta>
            </Query>
        </Vertex>
        <Vertex Label="profile" Type="UserProdile">

        </Vertex>
        <Edge Label="addresses" source="user" target="address" />
        <Edge Label="profile" source="user" target="profile" />
        <Edge Label="primaryAddress" source="user" target="addresses">
            <Meta>
                <Key>Description</Key>
                <Value>Resolves the user's primary address.</Value>
            </Meta>
        </Edge>
        <ScalarType Label="UserId">
            <Format
                Pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" />
        </ScalarType>
        <EntityType Label="User">
            <Property Label="userId" Type="Guid" isKey="true" />
            <Property Label="details" Type="UserDetails" />
        </EntityType>
        <ComplexType Label="UserDetails">
            <Property Label="firstName" Type="String">
                <Meta>
                    <Key>description</Key>
                    <Value>The first name of the user.</Value>
                </Meta>
            </Property>
            <Property Label="lastName" Type="String" />
            <Property Label="middleName" Type="String" />
            <Property Label="fullName" Type="String" />
            <Property Label="birthDate" Type="DateTime" />
            <Property Label="fullName" Type="String">
                <Resolver>

                </Resolver>
            </Property>
        </ComplexType>
        <ComplexType Label="UserUpdateOrCreate">
            <Property Label="firstName" Type="String" />
            <Property Label="lastName" Type="String" />
            <Property Label="middleName" Type="String" />
            <Property Label="fullName" Type="String" />
            <Property Label="birthDate" Type="DateTime" />
        </ComplexType>
        <CollectionType Label="UserCollection">
            <item Type="User" />
        </CollectionType>
        <ComplexType Label="UserTag">
            <Property Label="key" Type="String" />
            <Property Label="value" Type="String" />
        </ComplexType>
        <CollectionType Label="UserTagCollection">
            <Item Type="UserTag" />
        </CollectionType>
        <EntityType Label="UserAddress">
            <Property Label="streetOne" Type="String" />
            <Property Label="streetTwo" Type="String" />
            <Property Label="streetThree" Type="String" />
            <Property Label="city" Type="String" />
            <Property Label="state" Type="String" />
            <Property Label="zipCode" Type="String" />
            <Property Label="postalCode" Type="String" />
        </EntityType>
        <CollectionType Label="UserAddressCollection">
            <Item Type="UserAddress" />
        </CollectionType>
        <EntityType Label="UserProfile">
            <Property Label="emailAddress" Type="String" />
        </EntityType>
    </Graph>
    <Graph Label="employees" Uri="https://endpoint.com/api/employees/$graph">
        <!--
            Endpoints: 

                Reserved Routes:
                - GET       /api/employees/$graph

                Root Routes
                - GET       /api/employees
                - GET       /api/employees/{employeeId}
                - GET       /api/employees/archive
                - GET       /api/employees/archive/{employeeId}
                - DELETE    /api/employees/archive/{employeeId} (Hard Delete)
                - POST      /api/employees
                - PUT       /api/employees/{employeeId}
                - PATCH     /api/employees/{employeeId}
                - DELETE    /api/employees/{employeeId} (Soft Delete)

                - GET       /api/employees/addresses
                - GET       /api/employees/{employeeId}/addresses
                - GET       /api/employees/{employeeId}/addresses/{addressId}
                - POST      /api/employees/{employeeId}/addresses
                - PUT       /api/employees/{employeeId}/addresses/{addressId}
                - DELETE    /api/employees/{employeeId}/addresses/{addressId}

                - GET       /api/employees/{employeeId}/jobs
                - GET       /api/employees/{employeeId}/tasks
                - GET       /api/employees/{employeeId}/jobs/{jobId}/tasks
                - GET       /api/employees/{employeeId}/jobs/{jobId}/tasks/{taskId}/workItems
                - GET       /api/employees/{employeeId}/jobs/{jobId}/workItems
                - GET       /api/employees/{employeeId}/addresses

            [Command/Query] -> [Property Resolver] -> [Events] ->
         -->
        <Vertex Label="employees" Type="Employee">
            <!-- 
                Scenarios:
                    - Batch Employee updates
                    - Query Deleted Users
            -->

            <Query Label="GetEmployees">
                <ReturnType Type="EmployeeList" />
            </Query>
            <Query Label="GetEmployeeById">
                <ReturnType Type="Employee"/>
            </Query>
            <Command Label="CreateEmployee">
                <ReturnType Type="Employee" />
            </Command>
            <Command Label="UpdateEmployee">
                <ReturnType Type="Employee" />
            </Command>
            <Command Label="DeleteEmployee">
                <ReturnType Type="Employee" />
            </Command>
            <Command Label="PatchEmployee">
                <ReturnType Type="Employee" />
            </Command>

            <Query Label="GetEmployeeById">
                <ReturnType Type="Employee" />
            </Query>
            <Query Label="GetEmployees">
                <ReturnType Type="EmployeeList" />
            </Query>
            <Command Label="CreateEmployee" IsBound="true">
                <Parameter Label="" Type=""/>
                <ReturnType Type="Employee" />
            </Command>
            <Command Label="UpdateEmployee">
                <Parameter Label="employeeId" Type="EmployeeId" Kind="Key" IsRequired="true" />
                <Parameter Label="body" Type="EmployeeUpdateOrCreate" Kind="Input" IsRequired="true" />
                <ReturnType Type="Employee" />
            </Command>
            <Command Label="DeleteEmployee">
                <Parameter Label="employeeId" Type="EmployeeId" Kind="Route" />
                <ReturnType Type="Employee" />
            </Command>
            <Command Label="PatchEmployee" >
                <Parameter Type="" />
                <ReturnType Type="Employee" />
            </Command>


            <Event Label="EmployeeCreated">
                <After Binding="CreateEmployee" />
            </Event>
            <Event Label="EmployeeUpdating">
                <On Binding="UpdateEmployee" />
            </Event>
            <Event Label="BeginEmployeeDelete">
                <Before Binding="DeleteEmployee" />
            </Event>
           
            <Binding Label="" Kind="Query"> <!-- Query/Command/Event  -->
                <Parameter Label="employeeId" Kind="Route" />
                <Parameter Label="$query" Kind="Query" />
                <Parameter Label="employeeId" Kind="Route" />
                <ReturnType Type="Employee"/>
            </Binding>
            <Binding Label="" Kind="Event">

            </Binding>
            <!-- Bindings Concepts
                Operations

                    1. Must Return the bounded vertex entity type as either a collection of entities or a single entity

                Operation Actions
                    - QUERY
                    - 
            -->
            <Patameter Label="$query" Action="String">
                <Filtering Enabled="true" />
                <Sorting Enabled="true" />
                <Paging Enabled="true" />
            </Patameter>

            <Operation Label="GetEmployesById" Method="GET" Route="employees">
                <Parameter Label="employeeId" Type="EmployeeId" Kind="Route" IsRequired="true">

                </Parameter>
                <ReturnType Type="Employee" />
            </Operation>
            <Operation Label="GetEmployees" Method="GET" Route="employees/{employeeId}">
                <ReturnType Type="EmployeeList" />
            </Operation>
            <Operation Label="GetDeletedEmployees" Method="GET" Route="employees/archive">
                <ReturnType Type="EmployeeList" />
            </Operation>
            <Operation Label="GetDeletedEmployeeById" Method="GET" Route="employees/archive/{employeeId}">
                <ReturnType Type="Employee" />
            </Operation>
            <Operation Label="CreateEmployee">
                <ReturnType Type="Employee"/>
                <RequestType Type="EmployeeInput" />
            </Operation>
            <Operation Label="UpdateEmployee">
                <ReturnType Type="Employee"/>
                <RequestType Type="EmployeeInput" />
            </Operation>
            <Operation Label="DeleteEmployee">
                <ReturnType Type="Employee"/>
            </Operation>


            <Operation Label="GetEmployeeById">
                <Action Kind="Lookup"/>
                <Argument Label="employeeId" Type="EmployeeId"/>
                <Parameter Label="$query" Type="String" Kind="Query" />
                <Output Type="Employee" />
            </Operation>
            <Operation Label="CreateEmployee">
                <Action Kind="Create"/>
                <Parameter Label="$query" Type="String">
                    <Filtering Allowed="true" />
                    <Sorting Allowed="true" />
                    <Paging Allowed="true" />
                </Parameter>
                <Input Type="EmployeeCreateOrUpdate" />
                <Output Type="Employee" />
            </Operation>
            <Operation Label="UpdateEmployee">
                <Action Kind="Update" />
                <Parameter Label="$query" Type="String">
                    <Filtering Allowed="true" />
                    <Sorting Allowed="true" />
                    <Paging Allowed="true" />
                </Parameter>
                <Input Type="EmployeeInfo" />
                <Output Type="Employee" />
            </Operation>
            <Operation Label="DeleteEmployee">
                <Action Kind="Delete" />
                <Parameter Label="$query" Type="String">
                    <Filtering Allowed="true" />
                    <Sorting Allowed="true" />
                    <Paging Allowed="true" />
                    <Project Allowed="true" />
                </Parameter>
            </Operation>
            <Operation Label="PatchEmployee">
                <Action Kind="Patch" />
                <Parameter Label="$query" Type="String">
                    <Filtering Allowed="true" />
                    <Sorting Allowed="true" />
                    <Paging Allowed="true" />
                </Parameter>
                <Output Type="Employee" />
            </Operation>
            <Event Label="LogUserCreate">
                <Before Binding="CreateEmployee" />
            </Event>
            <Event Label="CreateUser">
                <After Binding="CreateEmployee" />
            </Event>
            <!-- Event Chaining -->
            <Event Label="NextEvent">
                <After Binding="CreateUser" />
            </Event>
            <Meta>
                <Key>description</Key>
                <Value></Value>
            </Meta>
        </Vertex>
