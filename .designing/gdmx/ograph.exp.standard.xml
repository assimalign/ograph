    <!-- Reference: https://cs.brown.edu/people/rtamassi/gdhandbook/chapters/Graphml.pdf -->
    <primitiveType Label="String" />
    <primitiveType Label="Date" />
    <primitiveType Label="DateTime" />
    <primitiveType Label="Time" />
    <primitiveType Label="Int16" />
    <primitiveType Label="Int32">
        <format>
            ^-?(?:[1-9]\d{0,8}|1\d{9}|20\d{8}|21[0-3]\d{7}|214[0-6]\d{6}|2147[0-3]\d{5}|21474[0-7]\d{4}|214748[0-2]\d{3}|2147483[0-5]\d{2}|21474836[0-3]\d|214748364[0-7])$</format>
    </primitiveType>
    <primitiveType Label="Int64" />
    <primitiveType Label="UInt16" />
    <primitiveType Label="UInt32" />
    <primitiveType Label="UInt64" />
