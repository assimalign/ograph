        <Edge Label="contacts" source="company" target="contact" />
        <Edge Label="addresses" source="company" target="address" />
        <Edge Label="types" source="address" target="addressType" />
        <EntityType Label="Company">

        </EntityType>
    </Graph>
</gdmx>