<?xml version="1.1" encoding="UTF-8"?>
<!-- <?xml-model href="ograph.model.schema.xsd"?> -->
<ograph>
    <!-- Use the collection of models to stich together a single cohesive 
        Things to Consider:
            - Method & Route Combination Conflicts

         There should be two types of models
         - Graph Relationship Model
         - Service Model: 

        Exmaple Routes: (User Domain)
        Users Node: label - users 
            - GET       /api/users
            - GET       /api/users/{userId}
            - POST      /api/users
            - PUT       /api/users/{userId}
            - DELETE    /api/users/{userId}

        Users Profile Node: label - profile [OneToOne]
            - GET       /api/users/profiles
            - GET       /api/users/{userId}/profile
            - POST      /api/users/{userId}/profile
            - PUT       /api/users/{userId}/profile
            - DELETE    /api/users/{userId}/profile

        Users Addresses: label - addresses [OneToMany]
            - GET       /api/users/addresses
            - GET       /api/users/{userId}/addresses
            - GET       /api/users/{userId}/primaryAddress [Edge]
            - GET       /api/users/{userId}/addresses/{addressId}
            - POST      /api/users/{userId}/addresses
            - PUT       /api/users/{userId}/addresses/{addressId}
            - DELETE    /api/users/{userId}/addresses/{addressId}

        Users Address Types Node: label - addresseTypes [OneToOne]
            - GET       /api/users/addressTypes
            - GET       /api/users/addresses/{addressId}/addressType
            - GET       /api/users/{userId}/addresses/{addressId}/addressType
            - POST      /api/users/addressTypes
            - PUT       /api/users/addressTypes/{addressTypeId}
            - DELETE    /api/users/addressTypes/{addressTypeId}
    -->
    <model label="users">
        <primitiveType label="String" />
        <primitiveType label="DateTime">
            <format></format>
        </primitiveType>
        <primitiveType label="Date" />
        <entityType label="User">
            <property label="userId" type="Guid" isKey="true" />
            <property label="details" type="UserDetails" />
        </entityType>
        <complexType label="UserDetails">
            <property label="firstName" type="String">
                <meta key="description" value="The first name of the user." />
            </property>
            <property label="lastName" type="String" />
            <property label="middleName" type="String" />
            <property label="fullName" type="String" />
            <property label="birthDate" type="DateTime" />
        </complexType>
        <complexType label="UserCreate">
            <property label="firstName" type="String" />
            <property label="lastName" type="String" />
            <property label="middleName" type="String" />
            <property label="fullName" type="String" />
            <property label="birthDate" type="DateTime" />
        </complexType>
        <collectionType label="UserCollection">
            <item type="User" />
        </collectionType>
        <complexType label="UserTag">
            <property label="key" type="String" />
            <property label="value" type="String" />
        </complexType>
        <collectionType label="UserTagCollection">
            <collection type="UserTag" />
        </collectionType>
        <entityType label="UserAddress">
            <property label="streetOne" type="String" />
            <property label="streetTwo" type="String" />
            <property label="streetThree" type="String" />
            <property label="city" type="String" />
            <property label="state" type="String" />
            <property label="zipCode" type="String" />
            <property label="postalCode" type="String" />
        </entityType>
        <collectionType label="UserAddressCollection">
            <collection type="UserAddress" />
        </collectionType>
        <entityType label="UserProfile">
            <property label="emailAddress" type="String" />
        </entityType>
        <vertex label="user" type="User" />
        <vertex label="address" type="UserAddress" />
        <vertex label="profile" type="UserProdile">
            
        </vertex>
        <edge label="addresses" source="user" target="address" cardinality="2" />
        <edge label="profile" source="user" target="profile" cardinality="1" />
        <edge label="primaryAddress" source="user" target="addresses" cardinality="1">
            <meta>
                <key></key>
                <value type=""></value>
            </meta>
        </edge>
        <!-- Operation Rules:
            1. All Operations must return an error result or an object/collection matching the type binded to
        tthe node
        -->
        <operations>
            <!-- User Operations -->
            <operation label="GetUsers" vertex="users">
                <method>GET</method>
                <type>QUERY</type>
                <route value="/users">
                    <segment ordinal="1" isLiteral="true">users</segment>
                </route>
                <queryParams>
                    <param key="query" type="String" />
                </queryParams>
                <response type="UserCollection" />
            </operation>
            <operation label="GetUserById" vertex="users">
                <method>GET</method>
                <type>QUERY</type>
                <route value="/users/{userId}">
                    <segment ordinal="1" is-literal="true">users</segment>
                    <segment ordinal="2" is-parameter="true">{userId:Guid}</segment>
                </route>
                <queryParams>
                    <param key="query" valueType="String" isRequired="false" />
                </queryParams>
            </operation>
            <operation label="CreateUser" vertex="users">
                <method>POST</method>
                <type>COMMAND</type>
                <route value="/users">
                    <segment ordinal="1" isLiteral="true">users</segment>
                </route>
            </operation>
            <!-- User Address Operations  -->
            <operation label="CreateUserAddress" vertex="addresses">
                <method>POST</method>
                <type>QUERY</type>
                <route value="/users/{userId}/addresses">
                    <segment ordinal="1" isLiteral="true">users</segment>
                    <segment ordinal="2" isParameter="true">{userId:Guid}</segment>
                    <segment ordinal="3" isLiteral="true">addresses</segment>
                </route>
            </operation>
            <operation label="GetUserProfile" vertex="profile">
                <method>GET</method>
                <type>QUERY</type>
                <route value="/users/{userId}/profile">
                    <segment ordinal="1" isLiteral="true">users</segment>
                    <segment ordinal="2" isParameter="true">{userId:Guid}</segment>
                    <segment ordinal="3" isLiteral="true">profile</segment>
                </route>
            </operation>

            <!-- User Address Type Operations -->
            <operation label="GetAddressTypes" vertex="addressTypes">
                <method>GET</method>
                <type>QUERY</type>
                <route value="/users/addressTypes">

                </route>
            </operation>
        </operations>


        <node>
            <label>users</label>

        </node>
        <edge>
            <label>addresses</label>
            <source>users</source>
            <target>addresses</target>
        </edge>
        <edge label="addresses" source-node="user" target-node="addresses" is-filterable="true"
            is-pageable="true" />
        <edge label="profile" source-node="user" target-node="profiles" />
        <node label="addresses" type="">

        </node>
        <node label="profiles">

        </node>
        <operation name="GetUsers" node="users" type="query">
            <method>GET</method>
            <route value="/users">
                <segment ordinal="1" is-literal="true">users</segment>
            </route>
        </operation>
        <operation name="CreateUser" node="users" type="command">
            <method>POST</method>
            <route value="/users/{userId}">
                <segment ordinal="1" is-literal="true">users</segment>
                <segment ordinal="2" is-parameter="true">{userId:int}</segment>
            </route>
            <query>

            </query>
            <headers>
                <header key="" value="" />
            </headers>
            <request>

            </request>
            <response>

            </response>
        </operation>
        <operation name="UpdateUserAddress" node="addresses" type="command">
            <method>PUT</method>
            <route value="/users/{userId}/addresses/{addressId}">
                <segment ordinal="1" is-literal="true">users</segment>
                <segment ordinal="2" is-parameter="true">{userId:Guid}</segment>
                <segment ordinal="3" is-literal="true">address</segment>
                <segment ordinal="4" is-parameter="true">{addressId:Guid}</segment>
            </route>
            <headers>
                <key></key>
            </headers>
            <query-parameters>
                <query key="query" value-type="" />
            </query-parameters>
            <request name="UserAddressUpdateType">

            </request>
            <response>

            </response>
        </operation>
    </model>
    <model label="employees">
        
    </model>
</ograph>