<?xml version="1.1" encoding="UTF-8"?>
<!-- <?xml-model href="ograph.model.schema.xsd"?> -->
<ograph>
    <!-- Use the collection of models to stich together a single cohesive 
        Things to Consider:
            - Method & Route Combination Conflicts

         There should be two types of models
         - Graph Relationship Model
         - Service Model: 

        Exmaple Routes: (User Domain)
        Users Node: label - users 
            - GET       /api/users
            - GET       /api/users/{userId}
            - POST      /api/users
            - PUT       /api/users/{userId}
            - DELETE    /api/users/{userId}

        Users Profile Node: label - profile [OneToOne]
            - GET       /api/users/profiles
            - GET       /api/users/{userId}/profile
            - POST      /api/users/{userId}/profile
            - PUT       /api/users/{userId}/profile
            - DELETE    /api/users/{userId}/profile

        Users Addresses: label - addresses [OneToMany]
            - GET       /api/users/addresses
            - GET       /api/users/{userId}/addresses
            - GET       /api/users/{userId}/primaryAddress [Edge]
            - GET       /api/users/{userId}/addresses/{addressId}
            - POST      /api/users/{userId}/addresses
            - PUT       /api/users/{userId}/addresses/{addressId}
            - DELETE    /api/users/{userId}/addresses/{addressId}

        Users Address Types Node: label - addresseTypes [OneToOne]
            - GET       /api/users/addressTypes
            - GET       /api/users/addresses/{addressId}/addressType
            - GET       /api/users/{userId}/addresses/{addressId}/addressType
            - POST      /api/users/addressTypes
            - PUT       /api/users/addressTypes/{addressTypeId}
            - DELETE    /api/users/addressTypes/{addressTypeId}
    -->
    <model domain="users">
        <types>
            <type name="User">
                <property name="userId" type="Guid" />
                <property name="firstName" type="String">
                    <meta key="description" value="The first name of the user." />
                </property>
                <property name="lastName" type="String" />
                <property name="middleName" type="String" />
                <property name="fullName" type="String" />
                <property name="birthDate" type="DateTime" />
            </type>
            <type name="UserCollection">
                <collection itemType="User" />
            </type>
            <type name="UserTagCollection">
                <collection itemType="UserTag" />
            </type>
            <type name="UserTag">
                <porperty name="key" type="String" />
                <porperty name="value" type="String" />
            </type>
            <type name="UserAddress">
                <property name="streetOne" type="String" />
                <property name="streetTwo" type="String" />
                <property name="streetThree" type="String" />
                <property name="city" type="String" />
                <property name="state" type="String" />
                <property name="zipCode" type="String" />
                <property name="postalCode" type="String" />
            </type>
            <type name="UserProfile">

            </type>
        </types>
        <vertices>
            <vertex label="users" type="User">
                <edge label="addresses" targetNode="addresses" />
                <edge label="primaryAddress" targetNode="addresses" />
                <edge label="profile" targetNode="profile" />
                <operation label="GetUsers" />
                <operation label="GetUserById" />
                <operation label="CreateUser" />
            </vertex>
            <vertex label="addresses" type="UserAddress">

            </vertex>
            <vertex label="profile" type="UserProdile">

            </vertex>
        </vertices>
        <edges>
            <edge label="addresses">
                <sourceNode label="users" /> <!-- XPath: //node[@label='user'] -->
                <targetNode label="addresses" />
            </edge>
            <edge label="profile">
                <sourceNode label="users" /> <!-- XPath: //node[@label='user'] -->
                <targetNode label="profile" />
            </edge>
        </edges>
        <!-- Operation Rules:
            1. All Operations must return an error result or an object/collection matching the type binded to
        tthe node
        -->
        <operations>
            <!-- User Operations -->
            <operation label="GetUsers" node="users">
                <method>GET</method>
                <type>QUERY</type>
                <route value="/users">
                    <segment ordinal="1" isLiteral="true">users</segment>
                </route>
            </operation>
            <operation label="GetUserById" node="users">
                <method>GET</method>
                <type>QUERY</type>
                <route value="/users/{userId}">
                    <segment ordinal="1" is-literal="true">users</segment>
                    <segment ordinal="2" is-parameter="true">{userId:Guid}</segment>
                </route>
            </operation>
            <operation label="CreateUser" node="users">
                <method>POST</method>
                <type>COMMAND</type>
                <route value="/users">
                    <segment ordinal="1" isLiteral="true">users</segment>
                </route>
            </operation>
            <!-- User Address Operations  -->
            <operation label="CreateUserAddress" node="addresses">
                <method>POST</method>
                <type>QUERY</type>
                <route value="/users/{userId}/addresses">
                    <segment ordinal="1" isLiteral="true">users</segment>
                    <segment ordinal="2" isParameter="true">{userId:Guid}</segment>
                    <segment ordinal="3" isLiteral="true">addresses</segment>
                </route>
            </operation>
            <operation label="GetUserProfile" node="profile">
                <method>GET</method>
                <type>QUERY</type>
                <route value="/users/{userId}/profile">
                    <segment ordinal="1" isLiteral="true">users</segment>
                    <segment ordinal="2" isParameter="true">{userId:Guid}</segment>
                    <segment ordinal="3" isLiteral="true">profile</segment>
                </route>
            </operation>

            <!-- User Address Type Operations -->
            <operation label="GetAddressTypes" node="addressTypes">
                <method>GET</method>
                <type>QUERY</type>
                <route value="/users/addressTypes">

                </route>
            </operation>
        </operations>


        <node>
            <label>users</label>

        </node>
        <edge>
            <label>addresses</label>
            <source>users</source>
            <target>addresses</target>
        </edge>
        <edge label="addresses" source-node="user" target-node="addresses" is-filterable="true"
            is-pageable="true" />
        <edge label="profile" source-node="user" target-node="profiles" />
        <node label="addresses" type="">

        </node>
        <node label="profiles">

        </node>
        <operation name="GetUsers" node="users" type="query">
            <method>GET</method>
            <route value="/users">
                <segment ordinal="1" is-literal="true">users</segment>
            </route>
        </operation>
        <operation name="CreateUser" node="users" type="command">
            <method>POST</method>
            <route value="/users/{userId}">
                <segment ordinal="1" is-literal="true">users</segment>
                <segment ordinal="2" is-parameter="true">{userId:int}</segment>
            </route>
            <query>

            </query>
            <headers>
                <header key="" value="" />
            </headers>
            <request>

            </request>
            <response>

            </response>
        </operation>
        <operation name="UpdateUserAddress" node="addresses" type="command">
            <method>PUT</method>
            <route value="/users/{userId}/addresses/{addressId}">
                <segment ordinal="1" is-literal="true">users</segment>
                <segment ordinal="2" is-parameter="true">{userId:Guid}</segment>
                <segment ordinal="3" is-literal="true">address</segment>
                <segment ordinal="4" is-parameter="true">{addressId:Guid}</segment>
            </route>
            <headers>
                <key></key>
            </headers>
            <query-parameters>
                <query key="query" value-type="" />
            </query-parameters>
            <request name="UserAddressUpdateType">

            </request>
            <response>

            </response>
        </operation>
    </model>
    <model domain="employees">
        <type name="employee">

        </type>
        <type name="employeeAddress">

        </type>
    </model>
</ograph>