{
  "name": "cursor-page",
  "title": "Cursor-mode paging metadata",
  "description": "A collection result under cursor-mode paging: $cursor.next carries an opaque continuation token and $total is null because the total is not computed for cursor traversal. Exercises the reserved cursor placeholders (§6.6). Cursor paging syntax is owned by S-03; this fixture pins only the envelope metadata shape.",
  "spec": ["§6.6"],
  "conformance": ["V-05"],
  "request": {
    "method": "QUERY",
    "route": "/hrm/employees",
    "headers": {
      "Content-Type": "application/vnd.ograph.query",
      "Accept": "application/vnd.ograph+json"
    },
    "body": "node(employees)\n  .sort(id asc)\n  .page(take: 2)\n  .project(id info { firstName lastName })"
  },
  "response": {
    "status": 200,
    "headers": {
