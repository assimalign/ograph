      "ETag": "\"7c2a-cursor-p0\""
    },
    "envelope": {
      "$status": 200,
      "$errors": [],
      "$count": 2,
      "$total": null,
      "$cursor": {
        "next": "eyJhZnRlciI6IjJmOWQ0YTEwIn0",
        "prev": null
      },
      "$nodes": [
        {
          "$uri": "/hrm/employees/2f9d4a10-6c2e-4b0a-9d21-7c1f0a2b8e44",
          "id": "2f9d4a10-6c2e-4b0a-9d21-7c1f0a2b8e44",
          "info": { "firstName": "Ada", "lastName": "Vance" }
        },
        {
